/* pages/installments/installments.wxss */

/* 自定义导航栏样式 */
.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #ffffff;
  /* 高度由padding-top和内容高度组成，不设置固定高度 */
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 16px;
}

.navbar-left {
  width: 80px;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  padding-left: 3px;
  overflow: visible;
  /* 完全去除所有默认样式 */
  background: none !important;
  background-color: transparent !important;
  border: none !important;
  outline: none !important;
  box-shadow: none !important;
  -webkit-tap-highlight-color: transparent !important;
  tap-highlight-color: transparent !important;
}

/* 去除所有可能的伪元素效果 */
.navbar-left::before,
.navbar-left::after {
  display: none !important;
  border: none !important;
  background: none !important;
}

/* 自定义点击反馈 - 仅图标变化 */
.navbar-left:active .stats-icon {
  opacity: 0.6;
  transform: scale(0.9);
  transition: all 0.1s ease;
}

.navbar-right {
  width: 80px;
  display: flex;
  align-items: center;
}



.navbar-title {
  font-size: 16px;
  font-weight: 400;
  color: #1f2937;
  flex: 1;
  text-align: center;
}



.stats-icon {
  width: 20px;
  height: 20px;
  filter: brightness(0);
}

/* 容器样式 */
.container {
  height: 100vh;
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  display: flex;
  flex-direction: column;
}

/* 分期列表样式 */
.installment-list {
  height: calc(100vh - 90rpx - env(safe-area-inset-bottom));
  width: 100%;
  padding: 0 24rpx;
  padding-bottom: 10px;
  box-sizing: border-box;
  overflow-y: auto;
}

/* 分期卡片样式 */
.installment-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 32rpx;
  padding: 40rpx;
  transition: all 0.3s ease;
  position: relative;
}

.installment-card:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 16rpx 50rpx rgba(0, 0, 0, 0.1);
}

.installment-card[data-status="completed"] {
  opacity: 0.75;
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 32rpx;
}

.card-info {
  flex: 1;
}

.card-name {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.card-number {
  display: block;
  font-size: 28rpx;
  color: #6b7280;
}

.amount-info {
  text-align: right;
}

.total-amount {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #2563eb;
  margin-bottom: 4rpx;
}

.amount-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
}

/* 进度条部分 */
.progress-section {
  margin-bottom: 32rpx;
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.progress-label {
  font-size: 28rpx;
  color: #4b5563;
}

.progress-text {
  font-size: 28rpx;
  color: #4b5563;
}

.progress-bar {
  width: 100%;
  height: 16rpx;
  background-color: #e5e7eb;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #10b981 0%, #34d399 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

/* 信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx;
  margin-bottom: 32rpx;
}

.info-item {
  text-align: center;
  padding: 24rpx;
  border-radius: 16rpx;
}

.info-item.gray {
  background-color: #f9fafb;
}

.info-item.blue {
  background-color: #eff6ff;
}

.info-item.green {
  background-color: #f0fdf4;
}

.info-item.red {
  background-color: #fef2f2;
}

.info-value {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.info-item.gray .info-value {
  color: #1f2937;
}

.info-item.blue .info-value {
  color: #2563eb;
}

.info-item.green .info-value {
  color: #16a34a;
}

.info-item.red .info-value {
  color: #dc2626;
}

.info-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
}

/* 最近还款时间 */
.last-payment {
  text-align: center;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.last-payment .iconfont {
  font-size: 28rpx;
  color: #6b7280;
}

.last-payment-text {
  font-size: 28rpx;
  color: #6b7280;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 24rpx;
}

.pay-btn, .cancel-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s ease;
}

/* 当撤销按钮隐藏时，按期还款按钮占满宽度 */
.pay-btn.full-width {
  flex: 1;
  width: 100%;
}

.pay-btn {
  background-color: #16a34a;
  color: #ffffff;
}

.pay-btn:hover {
  background-color: #15803d;
}

.cancel-btn {
  background-color: #6b7280;
  color: #ffffff;
}

.cancel-btn:hover {
  background-color: #4b5563;
}

.pay-btn .iconfont, .cancel-btn .iconfont {
  font-size: 32rpx;
}

/* 已完成标识 */
.completed-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 16rpx 32rpx;
  background-color: #dcfce7;
  color: #166534;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.completed-badge .iconfont {
  font-size: 32rpx;
}

/* 浮动添加按钮 */
.fab {
  position: fixed;
  right: 30rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom) + 30rpx);
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  z-index: 999;
  transition: all 0.3s ease;
}

.fab:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.fab-icon {
  font-size: 60rpx;
  color: white;
  font-weight: 300;
  line-height: 1;
}

/* 弹窗遮罩 */
.popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.popup-overlay.show {
  opacity: 1;
  visibility: visible;
}

/* 弹窗内容 */
.popup-content {
  background-color: #ffffff;
  border-radius: 48rpx 48rpx 0 0;
  width: 100%;
  max-height: 80vh;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.popup-overlay.show .popup-content {
  transform: translateY(0);
}

/* 弹窗标题栏 */
.popup-header {
  position: sticky;
  top: 0;
  background-color: #ffffff;
  border-radius: 48rpx 48rpx 0 0;
  padding: 32rpx 32rpx 24rpx 32rpx;
  border-bottom: 2rpx solid #f3f4f6;
  z-index: 10;
  display: flex;
  justify-content: center;
  align-items: center;
  box-sizing: border-box;
  position: relative;
}

.popup-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
}



.icon-close {
  color: #9ca3af;
  font-size: 40rpx;
  transition: color 0.3s ease;
  cursor: pointer;
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
}

.icon-close:active {
  color: #4b5563;
}

.icon-close:before {
  content: "✕";
}

/* 表单内容 */
.form-content {
  padding: 4px 32rpx 120rpx;
  max-height: calc(80vh - 200rpx);
  box-sizing: border-box;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #374151;
}

.form-label .iconfont {
  font-size: 32rpx;
}

.form-input, .form-picker {
  width: 100%;
  height: 88rpx;
  padding: 0 32rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 16rpx;
  font-size: 30rpx;
  background-color: #ffffff;
  transition: all 0.3s ease;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.form-picker {
  cursor: pointer;
  position: relative;
  justify-content: space-between;
}

.form-input::placeholder {
  color: #9ca3af;
  font-size: 28rpx;
}

.form-input:focus, .form-picker:focus {
  border-color: #3b82f6;
  box-shadow: 0 0 0 3rpx rgba(59, 130, 246, 0.1);
  outline: none;
}

.form-input.readonly {
  background-color: #f9fafb;
  color: #6b7280;
}

.picker-display {
  color: #374151;
  line-height: 40rpx;
  width: 100%;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  cursor: pointer;
  position: relative;
}

.picker-display text:first-child {
  text-align: left;
  color: #374151;
}

.picker-display text:first-child[data-placeholder="true"] {
  color: #9ca3af;
}

.picker-display .iconfont.icon-chevron-down {
  color: #9ca3af;
  font-size: 28rpx;
  transition: all 0.3s ease;
  font-weight: normal;
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
}

.picker-display .iconfont.icon-chevron-down:before {
  content: "⌄";
}

/* 表单操作按钮 */
.form-actions {
  display: flex;
  gap: 24rpx;
  padding-top: 32rpx;
  margin-bottom: 32rpx;
}

.form-actions .cancel-btn, .form-actions .save-btn {
  flex: 1;
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s ease;
}

.form-actions .cancel-btn {
  background-color: transparent;
  color: #374151;
  border: 2rpx solid #d1d5db;
}

.form-actions .cancel-btn:hover {
  background-color: #f9fafb;
}

.form-actions .save-btn {
  background-color: #2563eb;
  color: #ffffff;
}

.form-actions .save-btn:hover {
  background-color: #1d4ed8;
}

/* 统计弹窗 */
.stats-popup {
  background-color: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 0;
  width: 100%;
  max-width: 768rpx;
  margin: 0 auto;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.popup-overlay.show .stats-popup {
  transform: translateY(0);
}

.stats-content {
  margin-top: 0;
  padding: 40rpx;
}

.stats-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.stats-item.gray {
  background-color: #f9fafb;
}

.stats-item.green {
  background-color: #f0fdf4;
}

.stats-item.yellow {
  background-color: #fffbeb;
}

.stats-item.blue {
  background-color: #eff6ff;
}

.stats-item.purple {
  background-color: #faf5ff;
}

.stats-item.red {
  background-color: #fef2f2;
}

.stats-label {
  font-size: 28rpx;
  font-weight: 400;
}

.stats-item.gray .stats-label {
  color: #1f2937;
}

.stats-item.green .stats-label {
  color: #16a34a;
}

.stats-item.yellow .stats-label {
  color: #ea580c;
}

.stats-item.blue .stats-label {
  color: #2563eb;
}

.stats-item.purple .stats-label {
  color: #9333ea;
}

.stats-item.red .stats-label {
  color: #dc2626;
}

.stats-value {
  font-weight: 600;
  font-size: 28rpx;
}

.stats-item.gray .stats-value {
  color: #1f2937;
}

.stats-item.green .stats-value {
  color: #16a34a;
}

.stats-item.yellow .stats-value {
  color: #ea580c;
}

.stats-item.blue .stats-value {
  color: #2563eb;
}

.stats-item.purple .stats-value {
  color: #9333ea;
}

.stats-item.red .stats-value {
  color: #dc2626;
}



/* 响应式调整 */
@media (max-width: 750rpx) {
  .info-grid {
    gap: 24rpx;
  }
  
  .action-buttons {
    gap: 16rpx;
  }
  
  .popup-header {
    padding: 32rpx;
  }
  
  .form-content {
    padding: 0 32rpx 32rpx;
  }
}

/* 动画效果 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.installment-card {
  animation: fadeIn 0.3s ease;
}

/* 长按效果 */
.installment-card:active {
  transform: scale(0.98);
  transition: transform 0.1s ease;
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 6rpx;
}

::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 3rpx;
}

::-webkit-scrollbar-thumb {
  background: #c1c1c1;
  border-radius: 3rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: #a8a8a8;
}

/* 确认弹窗样式 */
.confirm-popup {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  border-radius: 48rpx 48rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  z-index: 1001;
}

.popup-overlay.show .confirm-popup {
  transform: translateY(0);
}

.confirm-content {
  padding: 48rpx;
  text-align: center;
}

.confirm-icon-wrapper {
  margin-bottom: 32rpx;
}

.confirm-icon-wrapper .iconfont {
  font-size: 80rpx;
}

.confirm-icon-wrapper .icon-credit-card {
  color: #16a34a;
}

.confirm-icon-wrapper .icon-undo {
  color: #f59e0b;
}

.confirm-title {
  display: block;
  font-size: 36rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.confirm-message {
  display: block;
  font-size: 32rpx;
  color: #6b7280;
  margin-bottom: 48rpx;
}

.confirm-details {
  background-color: #f9fafb;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 48rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.detail-label {
  font-size: 28rpx;
  color: #6b7280;
}

.detail-value {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 500;
}

.confirm-buttons {
  display: flex;
  gap: 24rpx;
}

.cancel-button {
  flex: 1;
  height: 88rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 16rpx;
  background-color: transparent;
  color: #6b7280;
  font-size: 32rpx;
  font-weight: 500;
}

.cancel-button::after {
  border: none;
}

.confirm-button {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
}

.confirm-button::after {
  border: none;
}

.confirm-button.pay {
  background-color: #16a34a;
}

.confirm-button.cancel {
  background-color: #f59e0b;
}

/* 空状态提示样式 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 36rpx;
  color: #374151;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #9ca3af;
  line-height: 1.5;
  max-width: 400rpx;
}

/* 日期选择器样式 */
.date-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
}

/* 选择器箭头 */
.selector-arrow {
  font-size: 24rpx;
  color: #9ca3af;
  transition: transform 0.3s ease;
  margin-left: 16rpx;
}

/* 清空图标 */
.clear-icon {
  font-size: 32rpx;
  color: #9ca3af;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  margin-left: 8rpx;
  transition: all 0.2s ease;
  background-color: transparent;
  font-weight: 500;
}

.clear-icon:active {
  background-color: #fee2e2;
  color: #ef4444;
  transform: scale(0.9);
}

/* 确保picker组件也能正确应用样式 */
picker.date-selector {
  display: flex !important;
  justify-content: space-between !important;
  align-items: center !important;
  cursor: pointer;
}

/* 强制picker内部元素布局 */
picker.date-selector > view {
  display: flex !important;
  justify-content: space-between !important;
  align-items: center !important;
  width: 100% !important;
}

.date-selector .placeholder {
  color: #999;
}

/* 还款日期选择器区域样式 */
.payment-date-section {
  margin-top: 12rpx;
  margin-bottom: 32rpx;
}

.payment-date-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.payment-date-label {
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
  flex-shrink: 0;
}

.payment-date-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 20rpx;
  background-color: #ffffff;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  cursor: pointer;
  transition: all 0.2s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  min-width: 200rpx;
  flex: 1;
  margin-left: 24rpx;
}

.payment-date-selector:active {
  border-color: #3b82f6;
  background-color: #f8fafc;
  transform: translateY(1rpx);
}

.payment-date-selector .date-text {
  font-size: 26rpx;
  color: #1f2937;
  font-weight: 500;
}

.payment-date-selector .placeholder {
  font-size: 26rpx;
  color: #9ca3af;
}

.calendar-icon {
  font-size: 28rpx;
  opacity: 0.7;
}

.date-picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 2000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.date-picker-overlay.show {
  opacity: 1;
  visibility: visible;
}

.date-picker-popup {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.date-picker-overlay.show .date-picker-popup {
  transform: translateY(0);
}

.date-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 50rpx 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
}

.date-picker-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.date-picker-close {
  font-size: 40rpx;
  color: #999;
  cursor: pointer;
  padding: 10rpx;
  line-height: 1;
}

.date-picker-content {
  flex: 1;
  padding: 20rpx 0;
  max-height: calc(80vh - 120rpx);
  overflow-y: auto;
}

.date-options {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 0 40rpx;
  min-height: 600rpx;
}

.date-option {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 16rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
  position: relative;
}

.date-option:hover {
  background: #e9ecef;
}

.date-option.selected {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-color: #667eea;
}

.date-option text {
  font-size: 28rpx;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.check-icon {
  font-size: 28rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
  position: absolute;
  right: 12rpx;
  top: 50%;
  transform: translateY(-50%);
}

.check-icon.show {
  opacity: 1;
}

/* 信用卡选择器样式 - 复用日期选择器样式 */
.card-options {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card-options .date-option {
  height: 100rpx;
  justify-content: space-between;
  padding: 0 32rpx;
  text-align: left;
  grid-template-columns: none;
}

.card-options .date-option text:first-child {
  flex: 1;
  text-align: left;
}
