/**index.wxss**/
/* 自定义导航栏样式 */
.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #ffffff;
  /* 高度由padding-top和内容高度组成，不设置固定高度 */
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 16px;
}

.navbar-left {
  width: 80px;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.navbar-right {
  width: 80px;
  display: flex;
  align-items: center;
}

.navbar-title {
  font-size: 16px;
  font-weight: 400;
  color: #1f2937;
  flex: 1;
  text-align: center;
}

/* 页面容器 */
.container {
  height: 100vh;
  background: #f9fafb;
  padding: 0;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  width: 0 !important;
  height: 0 !important;
  display: none !important;
}

::-webkit-scrollbar-track {
  display: none !important;
}

::-webkit-scrollbar-thumb {
  display: none !important;
}

::-webkit-scrollbar-corner {
  display: none !important;
}

page {
  -ms-overflow-style: none !important;
  scrollbar-width: none !important;
  overflow-x: hidden !important;
}



/* 卡片容器 */
.cards-container {
  flex: 1;
  width: 100%;
  padding: 0 40rpx 16rpx;
  box-sizing: border-box;
  overflow-y: auto;
  margin-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

/* 信用卡样式 */
.credit-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  color: white;
  position: relative;
  overflow: hidden;
  aspect-ratio: 2.0;
  transition: transform 0.2s ease;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.credit-card::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  pointer-events: none;
}

/* 卡片渐变样式 */
.card-gradient-blue {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.card-gradient-green {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.card-gradient-purple {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.card-gradient-orange {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.card-gradient-red {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.card-gradient-pink {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 40rpx;
}

.card-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.card-name {
  font-size: 32rpx;
  font-weight: 700;
  color: white;
}

.card-bank {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.card-icon {
  font-size: 48rpx;
  opacity: 0.8;
}

/* 卡号 */
.card-number {
  margin-bottom: 24rpx;
}

.card-number-text {
  font-size: 36rpx;
  font-weight: 400;
  letter-spacing: 4rpx;
  color: white;
  font-family: 'Courier New', monospace;
  word-break: keep-all;
  line-height: 1.4;
  white-space: nowrap;
  display: block;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 卡片底部信息 */
.card-footer {
  display: flex;
  justify-content: space-between;
}

.card-limit,
.card-due {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.card-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  text-transform: uppercase;
}

.card-value {
  font-size: 28rpx;
  font-weight: 600;
  color: white;
  word-wrap: break-word;
  overflow-wrap: break-word;
  hyphens: auto;
}

/* 浮动添加按钮 */
.floating-add-btn {
  position: fixed;
  right: 30rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom) + 30rpx);
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  z-index: 999;
  transition: all 0.3s ease;
}

.floating-add-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.floating-add-icon {
  font-size: 48rpx;
  color: white;
  font-weight: 300;
  line-height: 1;
}

/* 弹窗样式 */
.popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
}

.popup-bottom {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  opacity: 0;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.popup-header-fixed {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 50rpx 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  position: sticky;
  top: 0;
  z-index: 10;
  position: relative;
}

.popup-scroll-content {
  flex: 1;
  overflow-y: auto;
}

.popup-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.popup-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
  position: absolute;
  right: 50rpx;
  top: 50%;
  transform: translateY(-50%);
}

/* 表单容器 */
.form-container {
  padding: 40rpx 50rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 400;
  color: #666;
  margin-bottom: 20rpx;
}

.form-input {
  width: 100%;
  padding: 0 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #333;
  background: #f8f9fa;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
  text-align: left;
}

.form-input:focus {
  border-color: #667eea;
  background: white;
}

/* 样式选择网格 */
.style-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-top: 20rpx;
}

.style-item {
  height: 80rpx;
  border-radius: 16rpx;
  border: 4rpx solid transparent;
  cursor: pointer;
  transition: all 0.3s ease;
}

.style-item.selected {
  border-color: #333;
  transform: scale(1.05);
}

/* 提醒开关 */
.reminder-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.toggle-switch {
  width: 100rpx;
  height: 60rpx;
  background: #e0e0e0;
  border-radius: 30rpx;
  position: relative;
  transition: all 0.3s ease;
}

.toggle-switch.active {
  background: #667eea;
}

.toggle-dot {
  width: 52rpx;
  height: 52rpx;
  background: white;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.toggle-switch.active .toggle-dot {
  transform: translateX(40rpx);
}

/* 提醒选项 */
.reminder-options {
  margin-top: 30rpx;
  padding: 30rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.reminder-options.hidden {
  display: none;
}

.reminder-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.reminder-days {
  display: flex;
  gap: 20rpx;
}

.day-option {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  background: white;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
}

.day-option.selected {
  background: #667eea;
  border-color: #667eea;
  color: white;
}

/* 表单按钮 */
.form-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 60rpx;
}

.btn-cancel,
.btn-save {
  flex: 1;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
}

.btn-cancel {
  background: #f0f0f0;
  color: #666;
}

.btn-save {
  background: #667eea;
  color: white;
}

.btn-cancel:active {
  background: #e0e0e0;
}

.btn-save:active {
  background: #5a6fd8;
}

/* 自定义底部导航栏 */


/* 空状态提示 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
  opacity: 0.3;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  line-height: 1.6;
  max-width: 400rpx;
}

/* 日期选择器样式 */
.date-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
}

.date-selector .placeholder {
  color: #999;
}

.selector-arrow {
  font-size: 24rpx;
  color: #666;
  transition: transform 0.3s ease;
}

.date-picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 2000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.date-picker-overlay.show {
  opacity: 1;
  visibility: visible;
}

.date-picker-popup {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.date-picker-overlay.show .date-picker-popup {
  transform: translateY(0);
}

.date-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 50rpx 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
}

.date-picker-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.date-picker-close {
  font-size: 40rpx;
  color: #999;
  cursor: pointer;
  padding: 10rpx;
  line-height: 1;
}

.date-picker-content {
  flex: 1;
  padding: 20rpx 0;
  max-height: calc(80vh - 120rpx);
  overflow-y: auto;
}

.date-options {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 0 40rpx;
  min-height: 600rpx;
}

.date-option {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 16rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
  position: relative;
}

.date-option:hover {
  background: #e9ecef;
}

.date-option.selected {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-color: #667eea;
}

.date-option text {
  font-size: 28rpx;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.check-icon {
  font-size: 28rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
  position: absolute;
  right: 12rpx;
  top: 50%;
  transform: translateY(-50%);
}

.check-icon.show {
  opacity: 1;
}

/* 隐藏样式 */
.hidden {
  display: none !important;
}
