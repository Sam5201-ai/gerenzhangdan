/* pages/payment-history/payment-history.wxss */

/* 隐藏滚动条 */
::-webkit-scrollbar {
  width: 0 !important;
  height: 0 !important;
  display: none !important;
}

::-webkit-scrollbar-track {
  display: none !important;
}

::-webkit-scrollbar-thumb {
  display: none !important;
}

::-webkit-scrollbar-corner {
  display: none !important;
}

page {
  -ms-overflow-style: none !important;
  scrollbar-width: none !important;
  overflow-x: hidden !important;
}

/* 自定义导航栏样式 */
.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 16px;
}

.navbar-left {
  width: 80px;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.back-icon {
  font-size: 28px;
  color: white;
  font-weight: 300;
}

.navbar-right {
  width: 80px;
}

.navbar-title {
  font-size: 16px;
  font-weight: 500;
  color: white;
  flex: 1;
  text-align: center;
}

/* 页面容器 */
.container {
  height: 100vh;
  background: #f9fafb;
  padding: 0;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* 筛选栏 */
.filter-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 90;
  background: white;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.filter-buttons {
  display: flex;
  padding: 20rpx 32rpx;
  gap: 20rpx;
}

.filter-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid #e5e7eb;
  transition: all 0.3s ease;
}

.filter-btn:active {
  background: #f0f1f3;
  border-color: #667eea;
}

.filter-text {
  font-size: 28rpx;
  color: #1f2937;
}

.filter-arrow {
  font-size: 20rpx;
  color: #9ca3af;
}

/* 记录容器 */
.records-container {
  flex: 1;
  width: 100%;
  padding: 0 32rpx 32rpx;
  box-sizing: border-box;
  overflow-y: auto;
}

/* 月份分组 */
.month-section {
  margin-bottom: 48rpx;
  animation: fadeIn 0.3s ease-in;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.month-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 32rpx;
  margin-bottom: 24rpx;
  padding: 0 8rpx;
}

.month-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.month-total {
  font-size: 26rpx;
  color: #6b7280;
}

/* 还款记录卡片 */
.payment-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  border: 2rpx solid #f3f4f6;
  transition: all 0.3s ease;
}

.payment-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.card-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-left {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.card-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.icon-text {
  font-size: 48rpx;
}

.card-gradient-blue {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.card-gradient-green {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.card-gradient-purple {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

.card-gradient-orange {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.card-gradient-red {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.card-gradient-pink {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

.card-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.bank-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.card-number {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 8rpx;
}

.card-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.amount {
  font-size: 40rpx;
  font-weight: 700;
  color: #667eea;
}

.status-tag {
  padding: 6rpx 16rpx;
  background: #d1fae5;
  color: #059669;
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 24rpx;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 24rpx;
  border-top: 2rpx solid #f3f4f6;
}

.period-info,
.time-info {
  font-size: 24rpx;
  color: #6b7280;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
  opacity: 0.3;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #6b7280;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9ca3af;
}

/* 弹窗样式 */
.popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.popup-overlay.show {
  opacity: 1;
  visibility: visible;
}

.popup-bottom {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.popup-overlay.show .popup-bottom {
  transform: translateY(0);
}

.popup-header-fixed {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 50rpx 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  position: relative;
}

.popup-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.popup-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
  position: absolute;
  right: 50rpx;
  top: 50%;
  transform: translateY(-50%);
}

.popup-content {
  padding: 40rpx 50rpx 50rpx;
}

.popup-scroll-content {
  flex: 1;
  overflow-y: auto;
  max-height: calc(70vh - 120rpx);
  padding: 20rpx 0 50rpx;
}

/* 日期选择器 */
.date-picker-group {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  margin-bottom: 40rpx;
}

.picker-item {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.picker-label {
  font-size: 28rpx;
  font-weight: 500;
  color: #6b7280;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border: 2rpx solid #e5e7eb;
  font-size: 32rpx;
  color: #1f2937;
  transition: all 0.3s ease;
}

.picker-value:active {
  background: #f0f1f3;
  border-color: #667eea;
}

.picker-arrow {
  font-size: 32rpx;
  color: #9ca3af;
  font-weight: 300;
}

/* 弹窗按钮 */
.popup-buttons {
  display: flex;
  gap: 20rpx;
}

.btn-reset,
.btn-confirm {
  flex: 1;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
}

.btn-reset {
  background: #f0f0f0;
  color: #666;
}

.btn-confirm {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
}

.btn-reset:active {
  background: #e0e0e0;
}

.btn-confirm:active {
  opacity: 0.9;
}

/* 银行列表 */
.bank-list {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 0 50rpx;
}

.bank-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 24rpx;
  background: white;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.bank-item:active {
  background: #f8f9fa;
}

.bank-item.selected {
  background: rgba(102, 126, 234, 0.05);
}

.bank-text {
  font-size: 32rpx;
  color: #1f2937;
  font-weight: 500;
}

.bank-item.selected .bank-text {
  color: #667eea;
}

.check-icon {
  font-size: 36rpx;
  color: #667eea;
  font-weight: 700;
}

