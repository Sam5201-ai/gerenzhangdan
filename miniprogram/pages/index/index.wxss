/**index.wxss**/
/* 自定义导航栏样式 */
.custom-navbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #ffffff;
  /* 高度由padding-top和内容高度组成，不设置固定高度 */
}

.navbar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 16px;
}

.navbar-left {
  width: 80px;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.navbar-right {
  width: 80px;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.navbar-title {
  font-size: 16px;
  font-weight: 400;
  color: #1f2937;
  flex: 1;
  text-align: center;
}

/* 页面容器 */
.container {
  height: 100vh;
  background: #f9fafb;
  padding: 0;
  box-sizing: border-box;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  width: 0 !important;
  height: 0 !important;
  display: none !important;
}

::-webkit-scrollbar-track {
  display: none !important;
}

::-webkit-scrollbar-thumb {
  display: none !important;
}

::-webkit-scrollbar-corner {
  display: none !important;
}

page {
  -ms-overflow-style: none !important;
  scrollbar-width: none !important;
  overflow-x: hidden !important;
}



/* 卡片容器 */
.cards-container {
  flex: 1;
  width: 100%;
  padding: 0 40rpx 16rpx;
  box-sizing: border-box;
  overflow-y: auto;
  margin-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

/* 信用卡样式 */
.credit-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  color: white;
  position: relative;
  overflow: hidden;
  aspect-ratio: 2.0;
  transition: transform 0.2s ease;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

/* 卡片背景装饰基础样式 */
.card-decoration {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  overflow: hidden;
  z-index: 1;
}

.card-decoration::before,
.card-decoration::after {
  content: '';
  position: absolute;
  pointer-events: none;
  z-index: 1;
}


/* 卡片渐变样式 */
.card-gradient-blue {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

/* 蓝色卡片装饰 - 经典圆形 */
.credit-card.card-gradient-blue .card-decoration::before {
  top: -15%;
  right: -15%;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.35) 0%, rgba(255, 255, 255, 0.18) 40%, transparent 70%);
}

.credit-card.card-gradient-blue .card-decoration::after {
  bottom: -18%;
  left: -18%;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.28) 0%, transparent 60%);
}

.card-gradient-green {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

/* 绿色卡片装饰 - 六边形风格 */
.credit-card.card-gradient-green .card-decoration::before {
  top: 5%;
  left: 5%;
  width: 130rpx;
  height: 130rpx;
  clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%);
  background: radial-gradient(circle, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0.2) 50%, transparent 80%);
}

.credit-card.card-gradient-green .card-decoration::after {
  bottom: -15%;
  right: -15%;
  width: 160rpx;
  height: 160rpx;
  border-radius: 25%;
  background: conic-gradient(from 45deg, rgba(255, 255, 255, 0.3) 0deg, transparent 90deg, rgba(255, 255, 255, 0.22) 180deg, transparent 270deg);
}

.card-gradient-purple {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
}

/* 紫色卡片装饰 - 椭圆波浪风格 */
.credit-card.card-gradient-purple .card-decoration::before {
  top: 10%;
  right: -10%;
  width: 200rpx;
  height: 100rpx;
  border-radius: 50%;
  background: radial-gradient(ellipse, rgba(255, 255, 255, 0.35) 0%, rgba(255, 255, 255, 0.15) 50%, transparent 75%);
  transform: rotate(-15deg);
}

.credit-card.card-gradient-purple .card-decoration::after {
  bottom: -20%;
  left: -20%;
  width: 170rpx;
  height: 170rpx;
  border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
  background: linear-gradient(45deg, rgba(255, 255, 255, 0.28) 0%, rgba(255, 255, 255, 0.12) 60%, transparent 90%);
}

.card-gradient-orange {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

/* 橙色卡片装饰 - 星形菱形风格 */
.credit-card.card-gradient-orange .card-decoration::before {
  top: 8%;
  left: 8%;
  width: 110rpx;
  height: 110rpx;
  clip-path: polygon(50% 0%, 61% 35%, 98% 35%, 68% 57%, 79% 91%, 50% 70%, 21% 91%, 32% 57%, 2% 35%, 39% 35%);
  background: radial-gradient(circle, rgba(255, 255, 255, 0.45) 0%, rgba(255, 255, 255, 0.25) 50%, transparent 80%);
}

.credit-card.card-gradient-orange .card-decoration::after {
  bottom: -12%;
  right: -12%;
  width: 140rpx;
  height: 140rpx;
  transform: rotate(45deg);
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.32) 0%, rgba(255, 255, 255, 0.15) 40%, transparent 70%);
  border-radius: 20%;
}

.card-gradient-red {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

/* 红色卡片装饰 - 旋转几何风格 */
.credit-card.card-gradient-red .card-decoration::before {
  top: 12%;
  left: 10%;
  width: 100rpx;
  height: 100rpx;
  clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.4) 0%, rgba(255, 255, 255, 0.2) 60%, transparent 90%);
  transform: rotate(30deg);
}

.credit-card.card-gradient-red .card-decoration::after {
  bottom: -10%;
  right: -10%;
  width: 130rpx;
  height: 130rpx;
  border-radius: 15%;
  background: conic-gradient(from 0deg, rgba(255, 255, 255, 0.35) 0deg, transparent 90deg, rgba(255, 255, 255, 0.25) 180deg, transparent 270deg);
  transform: rotate(25deg);
}

.card-gradient-pink {
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
}

/* 粉色卡片装饰 - 花瓣心形风格 */
.credit-card.card-gradient-pink .card-decoration::before {
  top: 6%;
  right: 6%;
  width: 120rpx;
  height: 120rpx;
  border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
  background: radial-gradient(ellipse, rgba(255, 255, 255, 0.42) 0%, rgba(255, 255, 255, 0.2) 50%, transparent 75%);
  transform: rotate(-25deg);
}

.credit-card.card-gradient-pink .card-decoration::after {
  bottom: -18%;
  left: -18%;
  width: 150rpx;
  height: 150rpx;
  border-radius: 50% 20% 50% 20%;
  background: linear-gradient(45deg, rgba(255, 255, 255, 0.35) 0%, rgba(255, 255, 255, 0.18) 40%, transparent 70%);
  transform: rotate(45deg);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 40rpx;
  position: relative;
  z-index: 2;
}

.card-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.card-name {
  font-size: 32rpx;
  font-weight: 700;
  color: white;
}

/* 右上角额度 */
.card-limit-corner {
  position: absolute;
  top: 0;
  right: 0;
}

.limit-value {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.15);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  backdrop-filter: blur(10rpx);
}


.card-icon {
  font-size: 48rpx;
  opacity: 0.8;
}

/* 卡号 */
.card-number {
  margin-bottom: 24rpx;
}

.card-number-text {
  font-size: 36rpx;
  font-weight: 400;
  letter-spacing: 4rpx;
  color: white;
  font-family: 'Courier New', monospace;
  word-break: keep-all;
  line-height: 1.4;
  white-space: nowrap;
  display: block;
  width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 卡片底部信息 */
.card-footer {
  display: flex;
  justify-content: space-between;
  position: relative;
  z-index: 2;
}

/* 左下角分期欠款 */
.card-installment-debt {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.debt-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  text-transform: uppercase;
}

.debt-value {
  font-size: 32rpx;
  font-weight: 600;
  color: white;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.card-limit,
.card-due {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.card-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  text-transform: uppercase;
}

.card-value {
  font-size: 32rpx;
  font-weight: 600;
  color: white;
  word-wrap: break-word;
  overflow-wrap: break-word;
  hyphens: auto;
}

/* 浮动添加按钮 */
.floating-add-btn {
  position: fixed;
  right: 30rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom) + 30rpx);
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
  z-index: 999;
  transition: all 0.3s ease;
}

.floating-add-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.floating-add-icon {
  font-size: 60rpx;
  color: white;
  font-weight: 300;
  line-height: 1;
}

/* 弹窗样式 */
.popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}

.popup-overlay.show {
  opacity: 1;
  visibility: visible;
}

.popup-bottom {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.15);
  transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.popup-overlay.show .popup-bottom {
  transform: translateY(0);
}

.popup-header-fixed {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 50rpx 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  position: sticky;
  top: 0;
  z-index: 10;
  position: relative;
}

.popup-scroll-content {
  flex: 1;
  overflow-y: auto;
}

.popup-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.popup-close {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
  position: absolute;
  right: 50rpx;
  top: 50%;
  transform: translateY(-50%);
}

/* 表单容器 */
.form-container {
  padding: 40rpx 50rpx;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  font-weight: 400;
  color: #666;
  margin-bottom: 20rpx;
}

.form-input {
  width: 100%;
  padding: 0 30rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 16rpx;
  font-size: 30rpx;
  color: #333;
  background: #f8f9fa;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
  text-align: left;
}

.form-input:focus {
  border-color: #667eea;
  background: white;
}

/* 样式选择网格 */
.style-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  margin-top: 20rpx;
}

.style-item {
  height: 80rpx;
  border-radius: 16rpx;
  border: 4rpx solid transparent;
  cursor: pointer;
  transition: all 0.3s ease;
}

.style-item.selected {
  border-color: #333;
  transform: scale(1.05);
}

/* 提醒开关 */
.reminder-toggle {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.toggle-switch {
  width: 100rpx;
  height: 60rpx;
  background: #e0e0e0;
  border-radius: 30rpx;
  position: relative;
  transition: all 0.3s ease;
}

.toggle-switch.active {
  background: #667eea;
}

.toggle-dot {
  width: 52rpx;
  height: 52rpx;
  background: white;
  border-radius: 50%;
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.toggle-switch.active .toggle-dot {
  transform: translateX(40rpx);
}

/* 提醒选项 */
.reminder-options {
  margin-top: 30rpx;
  padding: 30rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}

.reminder-options.hidden {
  display: none;
}

.reminder-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.reminder-days {
  display: flex;
  gap: 20rpx;
}

.day-option {
  flex: 1;
  padding: 20rpx;
  text-align: center;
  background: white;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
}

.day-option.selected {
  background: #667eea;
  border-color: #667eea;
  color: white;
}

/* 表单按钮 */
.form-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 60rpx;
}

.btn-cancel,
.btn-save {
  flex: 1;
  padding: 28rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  transition: all 0.3s ease;
}

.btn-cancel {
  background: #f0f0f0;
  color: #666;
}

.btn-save {
  background: #667eea;
  color: white;
}

.btn-cancel:active {
  background: #e0e0e0;
}

.btn-save:active {
  background: #5a6fd8;
}

/* 自定义底部导航栏 */


/* 空状态提示 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  text-align: center;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
  opacity: 0.3;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
  line-height: 1.6;
  max-width: 400rpx;
}

/* 日期选择器样式 */
.date-selector {
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
}

.date-selector .placeholder {
  color: #999;
}

.selector-arrow {
  font-size: 24rpx;
  color: #666;
  transition: transform 0.3s ease;
}

.date-picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 2000;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.date-picker-overlay.show {
  opacity: 1;
  visibility: visible;
}

.date-picker-popup {
  background: white;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  box-shadow: 0 -8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.date-picker-overlay.show .date-picker-popup {
  transform: translateY(0);
}

.date-picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 50rpx 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
  background: white;
  border-radius: 32rpx 32rpx 0 0;
}

.date-picker-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
}

.date-picker-close {
  font-size: 40rpx;
  color: #999;
  cursor: pointer;
  padding: 10rpx;
  line-height: 1;
}

.date-picker-content {
  flex: 1;
  padding: 20rpx 0;
  max-height: calc(80vh - 120rpx);
  overflow-y: auto;
}

.date-options {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
  padding: 0 40rpx;
  min-height: 600rpx;
}

.date-option {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 16rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
  position: relative;
}

.date-option:hover {
  background: #e9ecef;
}

.date-option.selected {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border-color: #667eea;
}

.date-option text {
  font-size: 28rpx;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.check-icon {
  font-size: 28rpx;
  opacity: 0;
  transition: opacity 0.3s ease;
  position: absolute;
  right: 12rpx;
  top: 50%;
  transform: translateY(-50%);
}

.check-icon.show {
  opacity: 1;
}

/* 隐藏样式 */
.hidden {
  display: none !important;
}

/* 帮助图标样式 */
.help-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: white;
  border: 2rpx solid #667eea;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
}

.help-icon:active {
  transform: scale(0.95);
  background: rgba(102, 126, 234, 0.05);
}

.help-icon-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #667eea;
  line-height: 1;
}

/* 本地存储提示弹窗样式 */
.storage-tip-popup {
  max-height: 75vh;
}

.storage-tip-content {
  padding: 40rpx 50rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
}

.tip-icon {
  font-size: 120rpx;
  margin-bottom: 10rpx;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

.tip-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  text-align: center;
  width: 100%;
}

.tip-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.4;
}

.tip-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

.tip-list {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 30rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
  border-left: 6rpx solid #667eea;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.tip-bullet {
  font-size: 32rpx;
  color: #667eea;
  font-weight: 700;
  line-height: 1.4;
  flex-shrink: 0;
}

.tip-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  flex: 1;
  text-align: left;
}

.tip-confirm-btn {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  margin-top: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.3);
  transition: all 0.3s ease;
}

.tip-confirm-btn:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.25);
}
